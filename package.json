{
  "name": "kixvault",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint:fix": "biome check --write",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "dev:up": "docker compose --file docker-compose.dev.yml up -d",
    "dev:down": "docker compose --file docker-compose.dev.yml down",
    "dev:logs": "docker compose --file docker-compose.dev.yml logs -f",
    "prod:up": "docker compose --env-file .env up -d --build",
    "prod:down": "docker compose down",
    "prod:logs": "docker compose logs -f",
    "changeset": "changeset",
    "changeset:version": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^6.0.3"
  }
}
