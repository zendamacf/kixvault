{
  "name": "kixvault",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit && bun run --cwd apps/web typecheck && bun run --cwd apps/api typecheck && bun run --cwd packages/db typecheck && bun run --cwd packages/shared typecheck",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:studio": "bun run --cwd packages/db db:studio",
    "prod:up": "docker compose --env-file .env up -d --build",
    "prod:down": "docker compose down",
    "prod:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
