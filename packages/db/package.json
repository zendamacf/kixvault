{
  "name": "@kixvault/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun run --env-file ../../.env drizzle-kit generate",
    "db:migrate": "bun run --env-file ../../.env drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "drizzle-kit": "^0.31.4"
  }
}
