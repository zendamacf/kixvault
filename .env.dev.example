DATABASE_URL=postgresql://kixvault:kixvault@localhost:5433/kixvault
TEST_DATABASE_URL=postgresql://kixvault:kixvault@localhost:5433/kixvault_test
KICKSDB_API_KEY=KICKS-xxxx-xxxx-xxxx-xxxxxxxxxxxx
REDIS_URL=redis://localhost:6379

SIGNUPS_ENABLED=true

# API logging (silent disables request logs)
LOG_LEVEL=info

# API (Sentry project: kixvault-api)
SENTRY_RELEASE=

# Web (Vite — prefixed with VITE_ for client exposure)
VITE_APP_VERSION=

# Sentry source map upload (build time only — do not commit)
SENTRY_AUTH_TOKEN=
