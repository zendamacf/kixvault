# Caddy
DOMAIN=localhost
ACME_EMAIL=

# Docker Compose
POSTGRES_USER=kixvault
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=kixvault

# API container
DATABASE_URL=postgresql://kixvault:change-me-to-a-strong-password@db:5432/kixvault
KICKSDB_API_KEY=KICKS-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SENTRY_RELEASE=

NODE_ENV=production
PORT=3000

# Build-time vars (SENTRY_AUTH_TOKEN,
# VITE_APP_VERSION) are configured in GitHub repository settings
# and injected during the CI release workflow.
