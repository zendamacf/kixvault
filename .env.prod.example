# Caddy
DOMAIN=localhost
ACME_EMAIL=

# Docker Compose
POSTGRES_USER=kixvault
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=kixvault

# API container
DATABASE_URL=postgresql://kixvault:change-me-to-a-strong-password@db:5432/kixvault
KICKSDB_API_KEY=KICKS-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SENTRY_DSN=
SENTRY_RELEASE=

NODE_ENV=production
PORT=3000

# Web (set at Docker build time for Vite)
VITE_SENTRY_DSN=
VITE_APP_VERSION=

# Sentry source map upload (build time only — do not commit)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kalopsiadev
SENTRY_PROJECT=kixvault-api
