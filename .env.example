# -----------------------------------------------------------------------------
# Local development (docker-compose.dev.yml)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://kixvault:kixvault@localhost:5432/kixvault

# -----------------------------------------------------------------------------
# Production (docker-compose.yml)
# -----------------------------------------------------------------------------
DOMAIN=localhost
ACME_EMAIL=

POSTGRES_USER=kixvault
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=kixvault

# Used by the API container; hostname must be `db` in Docker Compose
DATABASE_URL=postgresql://kixvault:change-me-to-a-strong-password@db:5432/kixvault

NODE_ENV=production
PORT=3000

# Reserved for future auth hardening
SESSION_SECRET=change-me-to-a-long-random-string
